# MindArchive Production Hub — Environment Variables
# Copy this to .env.local and fill in your values

# Supabase (required for Vercel deployment)
# New Supabase key format (2025+)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# API keys can also be set via the Settings page in the app
# These env vars are used as fallbacks
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
PEXELS_API_KEY=
