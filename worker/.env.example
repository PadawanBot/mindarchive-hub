# Worker environment variables — copy to .env on EC2
# PM2: pm2 start ecosystem.config.cjs --env production

# Auth
WORKER_SECRET=your-shared-secret-here

# AI providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare R2 (video upload)
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token
R2_BUCKET=your-bucket-name
R2_PUBLIC_BASE=https://your-r2-public-domain.com

# Server
PORT=8081

# Debug (set to 1 to keep temp files after failed renders)
# PRESERVE_WORKDIR=0
