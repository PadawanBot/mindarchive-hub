# Worker environment variables — copy to .env on EC2
# PM2: pm2 start ecosystem.config.js

# Auth
WORKER_SECRET=your-shared-secret-here

# AI providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare R2 — S3-compatible API (preferred, supports up to 5 GB)
# Generate these in Cloudflare Dashboard > R2 > Manage R2 API Tokens > Create API Token
CLOUDFLARE_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-bucket-name
R2_PUBLIC_BASE=https://your-r2-public-domain.com

# Cloudflare REST API (legacy fallback, 100 MB limit)
# Only needed if R2_ACCESS_KEY_ID is not set
CLOUDFLARE_API_TOKEN=your-api-token

# Server
PORT=8081

# Debug (set to 1 to keep temp files after failed renders)
# PRESERVE_WORKDIR=0
